// Gb_standards clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace gb_standards {

    entity Substance {
        id: string @unique
        casNumber: string
        name: string
        formula: string
        molarMass: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Compound {
        id: string @unique
        inchiKey: string
        smiles: string
        name: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Structure {
        id: string @unique
        pdbId: string
        title: string
        method: string
        resolution: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Material {
        id: string @unique
        materialId: string
        formula: string
        bandGap: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Standard {
        id: string @unique
        designation: string
        title: string
        organization: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Property {
        id: string @unique
        substanceId: string
        name: string
        value: float
        unit: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
